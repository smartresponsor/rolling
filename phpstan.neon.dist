parameters:
    level: 5
    paths:
        - src
        - tests
        - bin
    tmpDir: var/phpstan
    excludePaths:
        analyse:
            - src/Legacy/Http/Role/Role/SymfonyBundle/Resources/config/services.php
            - tests/SDK/PHP/psr_stubs.php
    bootstrapFiles:
        - vendor/autoload.php
