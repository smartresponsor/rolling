export type AccessCheckRequest = {
  subjectId: string;
  action: string;
  scopeType: 'global' | 'tenant' | 'resource';
  tenantId?: string;
  resourceId?: string;
  context?: Record<string, unknown>;
};

export type AccessCheckResponse = {
  decision: 'ALLOW' | 'DENY';
  reason: string;
  obligations?: Array<{type:string; params:Record<string,unknown>}>;
  scope: string;
};

export class Client {
  constructor(private baseUrl: string, private opts: { apiKey?: string; hmacSecret?: string } = {}) {}
  async check(req: AccessCheckRequest): Promise<AccessCheckResponse> {
    const r = await fetch(this.baseUrl + '/v2/access/check', {
      method: 'POST',
      headers: {'content-type':'application/json'},
      body: JSON.stringify(req)
    });
    if (!r.ok) throw new Error(`HTTP ${r.status}`);
    return r.json();
  }
}
